# =============================================================================
# Imladris tmux — refined dark theme, Mountain time, dynamic window names
# =============================================================================

# --- True color support ---
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"

# --- Sane defaults ---
set -g mouse on
set -g history-limit 50000
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g escape-time 0
set -g focus-events on
set -g set-clipboard on

# --- Prefix: Ctrl-a (easier than Ctrl-b) ---
unbind C-b
set -g prefix C-a
bind C-a send-prefix

# --- Easy splits ---
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

# --- Easy pane navigation ---
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# --- Reload config ---
bind r source-file ~/.tmux.conf \; display "Config reloaded"

# =============================================================================
# Theme — Tokyo Night Storm
#
#   base:      #1a1b26  (deep navy-black)
#   surface:   #24283b  (raised surface)
#   overlay:   #3b4261  (borders, dividers)
#   muted:     #565f89  (comments, inactive)
#   text:      #c0caf5  (primary text)
#   accent:    #7aa2f7  (blue — primary accent)
#   purple:    #bb9af7  (secondary accent)
#   green:     #9ece6a  (success)
#   amber:     #e0af68  (warning)
# =============================================================================

# --- Status bar ---
set -g status-position bottom
set -g status-style "bg=#1a1b26,fg=#565f89"
set -g status-interval 5
set -g status-left-length 40
set -g status-right-length 55

# Left: session name in blue block
set -g status-left "#[fg=#1a1b26,bg=#7aa2f7,bold]  #S  #[fg=#7aa2f7,bg=#1a1b26] "

# Right: Mountain time + date
set -g status-right "#[fg=#3b4261]#[fg=#c0caf5,bg=#3b4261] #(TZ=America/Denver date +'%%I:%%M %%p') #[fg=#7aa2f7,bg=#3b4261]#[fg=#1a1b26,bg=#7aa2f7,bold] %b %d "

# --- Window tabs ---
setw -g window-status-format "#[fg=#565f89,bg=#1a1b26]  #I #W  "
setw -g window-status-current-format "#[fg=#24283b,bg=#1a1b26]#[fg=#c0caf5,bg=#24283b,bold] #I #W #[fg=#24283b,bg=#1a1b26]"
setw -g window-status-separator ""

# --- Pane borders ---
set -g pane-border-style "fg=#3b4261"
set -g pane-active-border-style "fg=#7aa2f7"

# --- Messages ---
set -g message-style "bg=#24283b,fg=#c0caf5"
set -g message-command-style "bg=#24283b,fg=#c0caf5"

# --- Clock ---
setw -g clock-mode-colour "#7aa2f7"
